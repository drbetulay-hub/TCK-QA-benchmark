# Copy to .env and fill with YOUR keys (never commit .env)

# OpenAI (GPT-4o, embeddings)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# LLM defaults
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# PostgreSQL (BasicRAG)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# BasicRAG: false = fixed top-10 (paper baseline)
BASIC_RAG_ADAPTIVE_RETRIEVAL=false
